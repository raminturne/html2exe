{
  "name": "app",
  "productName": "App",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron ."
  },
  "dependencies": {
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.local.app",
    "productName": "App",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "db.js",
      "app/**/*",
      "node_modules/sql.js/dist/sql-wasm.wasm",
      "node_modules/sql.js/dist/sql-wasm.js"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "portable": {
      "artifactName": "${productName}.exe"
    }
  }
}
