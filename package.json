{
  "name": "html2exe",
  "productName": "HTML2EXE",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "dist": "electron-builder build --win nsis"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.raminturne.html2exe",
    "productName": "HTML2EXE",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "extraResources": [
      { "from": "build.js", "to": "build.js" },
      { "from": "template", "to": "template" }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HTML2EXE",
      "artifactName": "HTML2EXE-Setup-${version}.exe"
    },
    "directories": {
      "output": "release"
    }
  }
}
